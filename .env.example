# Application
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Web Console
NEXT_PUBLIC_CONTROL_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_RUNTIME_BASE_URL=http://localhost:8000/runtime

# Control API
CONTROL_API_PORT=3001
RUNTIME_BASE_URL=http://localhost:8000
CONTROL_API_INTERNAL_BASE_URL=http://localhost:3001
AGENT_RUNTIME_EXECUTION_MODE=runtime_first
KNOWLEDGE_WORKFLOW_MODE=local
JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret
SECRET_ENCRYPTION_KEY=change-me-32-byte-encryption-key
MODEL_KEY_ENCRYPTION_SECRET=change-me-model-key-encryption-secret
DEFAULT_TENANT_CODE=default
DEFAULT_TENANT_NAME=Default Enterprise
DEFAULT_ADMIN_EMAIL=oss-admin-7f4c2a@local.invalid
DEFAULT_ADMIN_PASSWORD=AIAgetDev!9sK4pQ7m

# Agent Runtime
RUNTIME_PORT=8000
RUNTIME_CORS_ORIGIN=http://localhost:3000
RUNTIME_CONTROL_API_BASE_URL=http://localhost:3001
RUNTIME_INTERNAL_TOKEN=change-me-runtime-internal-token

# PostgreSQL
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=aiaget_platform
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://your-postgres-user:change-me-postgres-password@your-postgres-host:5432/aiaget_platform

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_URL=redis://your-redis-host:6379/0

# MinIO
MINIO_ENDPOINT=http://your-minio-host:9000
MINIO_CONSOLE=http://your-minio-host:9001
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=aiaget-files

# Qdrant
QDRANT_ENABLED=true
QDRANT_URL=http://your-qdrant-host:6333
QDRANT_API_KEY=change-me-qdrant-api-key
QDRANT_COLLECTION_PREFIX=aiaget_knowledge_segments

# OpenSearch
OPENSEARCH_URL=http://your-opensearch-host:9200
OPENSEARCH_ENABLED=true
OPENSEARCH_INDEX_PREFIX=aiaget_knowledge_segments
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# Temporal
TEMPORAL_ADDRESS=your-temporal-host:7233
TEMPORAL_POSTGRES_HOST=your-temporal-postgres-host
TEMPORAL_POSTGRES_PORT=5432
TEMPORAL_POSTGRES_USER=your-temporal-postgres-user
TEMPORAL_POSTGRES_PASSWORD=change-me-temporal-postgres-password
RUNTIME_TEMPORAL_ENABLED=false
RUNTIME_TEMPORAL_ADDRESS=your-temporal-host:7233
RUNTIME_TEMPORAL_NAMESPACE=default
RUNTIME_TEMPORAL_TASK_QUEUE=aiaget-knowledge-tasks

# Tool Gateway
TOOL_GATEWAY_RATE_LIMIT_PER_MINUTE=120
TOOL_GATEWAY_MAX_RETRIES=1
TOOL_GATEWAY_MAX_RESPONSE_CHARS=20000
