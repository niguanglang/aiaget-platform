# Copy this file to .env.production and replace every value before deployment.

# Application
NODE_ENV=production
CORS_ORIGIN=https://console.example.com

# Web Console
NEXT_PUBLIC_CONTROL_API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_RUNTIME_BASE_URL=https://runtime.example.com/runtime

# Control API
CONTROL_API_PORT=3001
RUNTIME_BASE_URL=http://agent-runtime:8000
CONTROL_API_INTERNAL_BASE_URL=http://control-api:3001
AGENT_RUNTIME_EXECUTION_MODE=runtime_first
KNOWLEDGE_WORKFLOW_MODE=runtime_first
AGENT_TEAM_WORKFLOW_MODE=runtime_first
CHANNEL_RELEASE_WORKFLOW_MODE=runtime_first
CHANNEL_RELEASE_SELF_HEALING_WORKFLOW_MODE=runtime_first
JWT_ACCESS_TOKEN_SECRET=replace-this-access-token-secret-with-32-plus-chars
JWT_REFRESH_TOKEN_SECRET=replace-this-refresh-token-secret-with-32-plus-chars
SECRET_ENCRYPTION_KEY=replace-this-32-byte-encryption-key!
MODEL_KEY_ENCRYPTION_SECRET=replace-this-model-key-secret-with-32-plus-chars
DEFAULT_TENANT_CODE=default
DEFAULT_TENANT_NAME=Default Enterprise
DEFAULT_ADMIN_EMAIL=oss-admin-7f4c2a@local.invalid
DEFAULT_ADMIN_PASSWORD=replace-this-admin-secret

# Agent Runtime
RUNTIME_PORT=8000
RUNTIME_CORS_ORIGIN=https://console.example.com
RUNTIME_CONTROL_API_BASE_URL=http://control-api:3001
RUNTIME_INTERNAL_TOKEN=replace-this-runtime-internal-token
RUNTIME_TEMPORAL_ENABLED=false
RUNTIME_TEMPORAL_ADDRESS=temporal:7233
RUNTIME_TEMPORAL_NAMESPACE=default
RUNTIME_TEMPORAL_TASK_QUEUE=aiaget-production

# PostgreSQL, external service only. Do not start a local PostgreSQL container for production.
POSTGRES_HOST=postgres.example.com
POSTGRES_PORT=5432
POSTGRES_DB=aiaget_platform
POSTGRES_USER=aiaget
POSTGRES_PASSWORD=replace-this-postgres-secret
DATABASE_URL=postgresql://aiaget:replace-this-postgres-secret@postgres.example.com:5432/aiaget_platform

# MinIO / S3-compatible storage, external service.
MINIO_ENDPOINT=http://minio.example.com:9000
MINIO_CONSOLE=http://minio.example.com:9001
MINIO_ROOT_USER=aiaget-minio
MINIO_ROOT_PASSWORD=replace-this-minio-secret
MINIO_BUCKET=aiaget-files
MINIO_REGION=us-east-1

# Qdrant, external service.
QDRANT_ENABLED=true
QDRANT_URL=http://qdrant.example.com:6333
QDRANT_API_KEY=replace-this-qdrant-secret
QDRANT_COLLECTION_PREFIX=aiaget_knowledge_segments

# OpenSearch, external service.
OPENSEARCH_ENABLED=true
OPENSEARCH_URL=http://opensearch.example.com:9200
OPENSEARCH_INDEX_PREFIX=aiaget_knowledge_segments
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# Tool Gateway
TOOL_GATEWAY_RATE_LIMIT_PER_MINUTE=120
TOOL_GATEWAY_MAX_RETRIES=1
TOOL_GATEWAY_MAX_RESPONSE_CHARS=20000

# Background operation tasks
CHANNEL_SENDER_TASK_ENABLED=true
CHANNEL_SENDER_TASK_INTERVAL_MS=60000
CHANNEL_RELEASE_SCHEDULER_ENABLED=false
CHANNEL_RELEASE_SCHEDULER_INTERVAL_MS=120000
PLATFORM_USAGE_ALERT_NOTIFICATION_TASK_ENABLED=true
SECURITY_OPERATION_ALERT_AUTO_NOTIFY_ENABLED=true
SECURITY_OPERATION_ALERT_NOTIFICATION_TASK_ENABLED=true
SECURITY_OPERATION_ALERT_SLA_ENABLED=true
