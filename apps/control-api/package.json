{
  "name": "@aiaget/control-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://aiaget:aiaget_dev_password@localhost:5432/aiaget} prisma generate",
    "prisma:deploy": "DATABASE_URL=${DATABASE_URL:-postgresql://aiaget:aiaget_dev_password@localhost:5432/aiaget} prisma migrate deploy",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://aiaget:aiaget_dev_password@localhost:5432/aiaget} prisma migrate dev",
    "prisma:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://aiaget:aiaget_dev_password@localhost:5432/aiaget} tsx prisma/seed.ts",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://aiaget:aiaget_dev_password@localhost:5432/aiaget} prisma validate",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aiaget/shared-types": "workspace:*",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@aiaget/tsconfig": "workspace:*",
    "@types/express": "5.0.6",
    "prisma": "6.19.3",
    "tsx": "4.21.0"
  }
}
