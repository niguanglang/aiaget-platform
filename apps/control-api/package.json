{
  "name": "@aiaget/control-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint src",
    "prisma:comments": "set -a && . ../../.env && set +a && prisma db execute --file ../../scripts/postgres_comments.sql --schema prisma/schema.prisma",
    "prisma:generate": "set -a && . ../../.env && set +a && prisma generate",
    "prisma:deploy": "set -a && . ../../.env && set +a && prisma migrate deploy && prisma db execute --file ../../scripts/postgres_comments.sql --schema prisma/schema.prisma",
    "prisma:migrate": "set -a && . ../../.env && set +a && prisma migrate dev && prisma db execute --file ../../scripts/postgres_comments.sql --schema prisma/schema.prisma",
    "prisma:seed": "set -a && . ../../.env && set +a && tsx prisma/seed.ts",
    "prisma:validate": "set -a && . ../../.env && set +a && prisma validate",
    "start": "node dist/main.js",
    "test": "node ../../scripts/run-control-api-tests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aiaget/shared-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@aiaget/tsconfig": "workspace:*",
    "@types/express": "5.0.6",
    "prisma": "6.19.3",
    "tsx": "4.21.0"
  }
}
