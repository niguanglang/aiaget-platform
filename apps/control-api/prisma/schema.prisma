  createdBy            String?                @map("created_by") @db.Uuid
  updatedBy            String?                @map("updated_by") @db.Uuid
  tenant               Tenant                 @relation(fields: [tenantId], references: [id])
  agent                Agent                  @relation(fields: [agentId], references: [id])
  user                 User?                  @relation("ConversationUser", fields: [userId], references: [id])
  messages             ConversationMessage[]
  runs                 ConversationRun[]
  feedback             ConversationFeedback[]
  toolApprovalRequests ToolApprovalRequest[]

  @@index([tenantId])
  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("conversation")
}

model ConversationRun {
  id               String                 @id @default(uuid()) @db.Uuid
  tenantId         String                 @map("tenant_id") @db.Uuid
  conversationId   String                 @map("conversation_id") @db.Uuid
  agentId          String                 @map("agent_id") @db.Uuid
  status           String                 @db.VarChar(30)
  requestModel     String?                @map("request_model") @db.VarChar(160)
  promptTokens     Int                    @default(0) @map("prompt_tokens")
  completionTokens Int                    @default(0) @map("completion_tokens")
  totalTokens      Int                    @default(0) @map("total_tokens")
  latencyMs        Int                    @default(0) @map("latency_ms")
  steps            Json?
  errorMessage     String?                @map("error_message") @db.Text
  startedAt        DateTime?              @map("started_at")
  endedAt          DateTime?              @map("ended_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  createdBy        String?                @map("created_by") @db.Uuid
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  conversation     Conversation           @relation(fields: [conversationId], references: [id])
  agent            Agent                  @relation(fields: [agentId], references: [id])
  operator         User?                  @relation("ConversationRunOperator", fields: [createdBy], references: [id])
  messages         ConversationMessage[]
  feedback         ConversationFeedback[]

  @@index([tenantId])
  @@index([conversationId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("conversation_run")
}

model ConversationMessage {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  runId          String?          @map("run_id") @db.Uuid
  role           String           @db.VarChar(20)
  content        String           @db.Text
  references     Json?
  toolCalls      Json?            @map("tool_calls")
  createdAt      DateTime         @default(now()) @map("created_at")
  createdBy      String?          @map("created_by") @db.Uuid
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  conversation   Conversation     @relation(fields: [conversationId], references: [id])
  run            ConversationRun? @relation(fields: [runId], references: [id])
  author         User?            @relation("ConversationMessageAuthor", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([runId])
  @@index([role])
  @@index([createdAt])
  @@map("conversation_message")
}

model ConversationFeedback {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  runId          String?          @map("run_id") @db.Uuid
  rating         Int
  comment        String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  createdBy      String?          @map("created_by") @db.Uuid
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  conversation   Conversation     @relation(fields: [conversationId], references: [id])
  run            ConversationRun? @relation(fields: [runId], references: [id])
  author         User?            @relation("ConversationFeedbackAuthor", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([runId])
  @@index([createdAt])
  @@map("conversation_feedback")
}

model SecurityPolicy {
  id           String                     @id @default(uuid()) @db.Uuid
  tenantId     String                     @map("tenant_id") @db.Uuid
  name         String                     @db.VarChar(160)
  code         String                     @db.VarChar(100)
  description  String?                    @db.Text
  effect       String                     @default("DENY") @db.VarChar(20)
  resourceType String                     @map("resource_type") @db.VarChar(80)
  action       String                     @db.VarChar(120)
  priority     Int                        @default(100)
  status       String                     @default("ACTIVE") @db.VarChar(30)
  conditions   Json?
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  deletedAt    DateTime?                  @map("deleted_at")
  createdBy    String?                    @map("created_by") @db.Uuid
  updatedBy    String?                    @map("updated_by") @db.Uuid
  tenant       Tenant                     @relation(fields: [tenantId], references: [id])
  creator      User?                      @relation("SecurityPolicyCreator", fields: [createdBy], references: [id])
  updater      User?                      @relation("SecurityPolicyUpdater", fields: [updatedBy], references: [id])
  evaluations  SecurityPolicyEvaluation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([effect])
  @@index([resourceType])
  @@index([action])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("security_policy")
}

model SecurityPolicyEvaluation {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  requestId         String          @map("request_id") @db.VarChar(120)
  traceId           String?         @map("trace_id") @db.VarChar(120)
  subject           Json
  resource          Json
  action            String          @db.VarChar(120)
  decision          String          @db.VarChar(30)
  matchedPolicyId   String?         @map("matched_policy_id") @db.Uuid
  matchedPolicyCode String?         @map("matched_policy_code") @db.VarChar(100)
  reason            String          @db.Text
  context           Json?
  createdAt         DateTime        @default(now()) @map("created_at")
  createdBy         String?         @map("created_by") @db.Uuid
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  matchedPolicy     SecurityPolicy? @relation(fields: [matchedPolicyId], references: [id])
  operator          User?           @relation("SecurityPolicyEvaluationOperator", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([requestId])
  @@index([traceId])
  @@index([action])
  @@index([decision])
  @@index([matchedPolicyId])
  @@index([createdAt])
  @@map("security_policy_evaluation")
}
