generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                        String                     @id @default(uuid()) @db.Uuid
  code                      String                     @unique @db.VarChar(80)
  name                      String                     @db.VarChar(160)
  status                    String                     @default("ACTIVE") @db.VarChar(30)
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  deletedAt                 DateTime?                  @map("deleted_at")
  createdBy                 String?                    @map("created_by") @db.Uuid
  updatedBy                 String?                    @map("updated_by") @db.Uuid
  users                     User[]
  departments               Department[]
  roles                     Role[]
  permissions               Permission[]
  menus                     Menu[]
  roleMenus                 RoleMenu[]
  roleDataScopes            RoleDataScope[]
  resourceAcls              ResourceAcl[]
  apiKeys                   ApiKey[]
  systemSettings            SystemSetting[]
  systemSettingSnapshots    SystemSettingSnapshot[]
  loginLogs                 LoginLog[]
  operationLogs             OperationLog[]
  refreshTokens             RefreshToken[]
  agentCategories           AgentCategory[]
  agents                    Agent[]
  agentTeams                AgentTeam[]
  agentTeamMembers          AgentTeamMember[]
  agentTeamRuns             AgentTeamRun[]
  agentTeamSteps            AgentTeamStep[]
  agentTeamHandoffs         AgentTeamHandoff[]
  agentTeamFeedback         AgentTeamFeedback[]
  agentVersions             AgentVersion[]
  agentModelBindings        AgentModelBinding[]
  agentPromptBindings       AgentPromptBinding[]
  agentKnowledgeBindings    AgentKnowledgeBinding[]
  agentToolBindings         AgentToolBinding[]
  agentPublishChannels      AgentPublishChannel[]
  channelProviders          ChannelProvider[]
  channelAccounts           ChannelAccount[]
  channelTemplates          ChannelTemplate[]
  channelPublishJobs        ChannelPublishJob[]
  channelDeliveries         ChannelDelivery[]
  channelReplies            ChannelReply[]
  channelRouteRules         ChannelRouteRule[]
  agentAuditLogs            AgentAuditLog[]
  modelProviders            ModelProvider[]
  modelConfigs              ModelConfig[]
  modelApiKeys              ModelApiKey[]
  modelCostRules            ModelCostRule[]
  modelCallLogs             ModelCallLog[]
  promptTemplates           PromptTemplate[]
  promptVersions            PromptVersion[]
  promptVariables           PromptVariable[]
  promptTestRecords         PromptTestRecord[]
  knowledgeBases            KnowledgeBase[]
  knowledgeDocuments        KnowledgeDocument[]
  knowledgeSegments         KnowledgeSegment[]
  knowledgeEmbeddingTasks   KnowledgeEmbeddingTask[]
  knowledgeRecallLogs       KnowledgeRecallLog[]
  tools                     Tool[]
  toolCallLogs              ToolCallLog[]
  toolApprovalRequests      ToolApprovalRequest[]
  approvalAuditEvents       ApprovalAuditEvent[]
  conversations             Conversation[]
  conversationMessages      ConversationMessage[]
  conversationRuns          ConversationRun[]
  conversationFeedback      ConversationFeedback[]
  securityPolicies          SecurityPolicy[]
  securityPolicyEvaluations SecurityPolicyEvaluation[]
  webhookDeliveries         WebhookDelivery[]
  channelSenderDeliveries   ChannelSenderDelivery[]
  platformEvents            PlatformEvent[]
  platformEventRelations    PlatformEventRelation[]
  platformUsageEvents       PlatformUsageEvent[]
  platformUsageRollups      PlatformUsageRollup[]
  billingPlans              BillingPlan[]
  tenantSubscriptions       TenantSubscription[]
  billingInvoices           BillingInvoice[]
  billingInvoiceItems       BillingInvoiceLineItem[]
  billingQuotaPolicies      BillingQuotaPolicy[]
  billingAdjustments        BillingAdjustment[]
  plugins                   Plugin[]
  pluginVersions            PluginVersion[]
  pluginInstallations       PluginInstallation[]
  pluginHooks               PluginHook[]
  pluginMenuBindings        PluginMenuBinding[]
  pluginAuditLogs           PluginAuditLog[]

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("tenant")
}

model User {
  id                            String                     @id @default(uuid()) @db.Uuid
  tenantId                      String                     @map("tenant_id") @db.Uuid
  departmentId                  String?                    @map("department_id") @db.Uuid
  email                         String                     @db.VarChar(180)
  name                          String                     @db.VarChar(120)
  passwordHash                  String                     @map("password_hash") @db.VarChar(255)
  status                        String                     @default("ACTIVE") @db.VarChar(30)
  lastLoginAt                   DateTime?                  @map("last_login_at")
  createdAt                     DateTime                   @default(now()) @map("created_at")
  updatedAt                     DateTime                   @updatedAt @map("updated_at")
  deletedAt                     DateTime?                  @map("deleted_at")
  createdBy                     String?                    @map("created_by") @db.Uuid
  updatedBy                     String?                    @map("updated_by") @db.Uuid
  tenant                        Tenant                     @relation(fields: [tenantId], references: [id])
  department                    Department?                @relation("DepartmentMembers", fields: [departmentId], references: [id])
  userRoles                     UserRole[]
  ledDepartments                Department[]               @relation("DepartmentLeader")
  loginLogs                     LoginLog[]
  operationLogs                 OperationLog[]
  refreshTokens                 RefreshToken[]
  ownedAgents                   Agent[]                    @relation("AgentOwner")
  ownedAgentTeams               AgentTeam[]                @relation("AgentTeamOwner")
  ownedPlugins                  Plugin[]                   @relation("PluginOwner")
  operatedAgentTeamRuns         AgentTeamRun[]             @relation("AgentTeamRunOperator")
  decidedAgentTeamHandoffs      AgentTeamHandoff[]         @relation("AgentTeamHandoffDecider")
  createdAgentTeamFeedback      AgentTeamFeedback[]        @relation("AgentTeamFeedbackAuthor")
  createdAgentVersions          AgentVersion[]             @relation("AgentVersionCreator")
  agentAuditLogs                AgentAuditLog[]            @relation("AgentAuditOperator")
  ownedPromptTemplates          PromptTemplate[]           @relation("PromptTemplateOwner")
  createdPromptVersions         PromptVersion[]            @relation("PromptVersionCreator")
  promptTestRecords             PromptTestRecord[]         @relation("PromptTestOperator")
  ownedKnowledgeBases           KnowledgeBase[]            @relation("KnowledgeBaseOwner")
  uploadedKnowledgeDocuments    KnowledgeDocument[]        @relation("KnowledgeDocumentUploader")
  knowledgeRecallLogs           KnowledgeRecallLog[]       @relation("KnowledgeRecallOperator")
  toolCallLogs                  ToolCallLog[]              @relation("ToolCallOperator")
  requestedToolApprovals        ToolApprovalRequest[]      @relation("ToolApprovalRequester")
  reviewedToolApprovals         ToolApprovalRequest[]      @relation("ToolApprovalReviewer")
  approvalAuditEvents           ApprovalAuditEvent[]       @relation("ApprovalAuditActor")
  conversations                 Conversation[]             @relation("ConversationUser")
  conversationMessages          ConversationMessage[]      @relation("ConversationMessageAuthor")
  conversationRuns              ConversationRun[]          @relation("ConversationRunOperator")
  conversationFeedback          ConversationFeedback[]     @relation("ConversationFeedbackAuthor")
  createdSecurityPolicies       SecurityPolicy[]           @relation("SecurityPolicyCreator")
  updatedSecurityPolicies       SecurityPolicy[]           @relation("SecurityPolicyUpdater")
  securityPolicyEvaluations     SecurityPolicyEvaluation[] @relation("SecurityPolicyEvaluationOperator")
  updatedSystemSettings         SystemSetting[]            @relation("SystemSettingUpdater")
  createdSystemSettingSnapshots SystemSettingSnapshot[]    @relation("SystemSettingSnapshotCreator")
  platformEvents                PlatformEvent[]            @relation("PlatformEventUser")
  platformUsageEvents           PlatformUsageEvent[]       @relation("PlatformUsageEventUser")
  pluginInstallations           PluginInstallation[]       @relation("PluginInstallationOwner")
  pluginVersionsCreated         PluginVersion[]            @relation("PluginVersionCreator")
  pluginHooksCreated            PluginHook[]               @relation("PluginHookCreator")
  pluginMenuBindingsCreated     PluginMenuBinding[]        @relation("PluginMenuBindingCreator")
  pluginAuditLogs               PluginAuditLog[]           @relation("PluginAuditOperator")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("user")
}

model Department {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  parentId     String?      @map("parent_id") @db.Uuid
  name         String       @db.VarChar(120)
  code         String       @db.VarChar(100)
  description  String?      @db.Text
  leaderUserId String?      @map("leader_user_id") @db.Uuid
  sortOrder    Int          @default(0) @map("sort_order")
  status       String       @default("ACTIVE") @db.VarChar(30)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  createdBy    String?      @map("created_by") @db.Uuid
  updatedBy    String?      @map("updated_by") @db.Uuid
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  parent       Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children     Department[] @relation("DepartmentTree")
  leader       User?        @relation("DepartmentLeader", fields: [leaderUserId], references: [id])
  members      User[]       @relation("DepartmentMembers")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([leaderUserId])
  @@index([status])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("department")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  code            String           @db.VarChar(80)
  name            String           @db.VarChar(120)
  description     String?          @db.Text
  status          String           @default("ACTIVE") @db.VarChar(30)
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  createdBy       String?          @map("created_by") @db.Uuid
  updatedBy       String?          @map("updated_by") @db.Uuid
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  roleMenus       RoleMenu[]
  dataScopes      RoleDataScope[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("role")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  code            String           @db.VarChar(120)
  name            String           @db.VarChar(160)
  module          String           @db.VarChar(80)
  resource        String           @default("") @db.VarChar(80)
  action          String           @db.VarChar(80)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")
  createdBy       String?          @map("created_by") @db.Uuid
  updatedBy       String?          @map("updated_by") @db.Uuid
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([module])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("permission")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId, roleId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("user_role")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  createdBy    String?    @map("created_by") @db.Uuid
  updatedBy    String?    @map("updated_by") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId, roleId, permissionId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("role_permission")
}

model Menu {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  parentId           String?             @map("parent_id") @db.Uuid
  name               String              @db.VarChar(120)
  code               String              @db.VarChar(100)
  type               String              @db.VarChar(20)
  path               String?             @db.VarChar(255)
  component          String?             @db.VarChar(255)
  icon               String?             @db.VarChar(100)
  permissionCode     String?             @map("permission_code") @db.VarChar(120)
  isExternal         Boolean             @default(false) @map("is_external")
  externalUrl        String?             @map("external_url") @db.VarChar(500)
  redirectPath       String?             @map("redirect_path") @db.VarChar(255)
  keepAlive          Boolean             @default(false) @map("keep_alive")
  affix              Boolean             @default(false)
  hideBreadcrumb     Boolean             @default(false) @map("hide_breadcrumb")
  routeMeta          Json?               @map("route_meta")
  sortOrder          Int                 @default(0) @map("sort_order")
  visible            Boolean             @default(true)
  enabled            Boolean             @default(true)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  createdBy          String?             @map("created_by") @db.Uuid
  updatedBy          String?             @map("updated_by") @db.Uuid
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  parent             Menu?               @relation("MenuTree", fields: [parentId], references: [id])
  children           Menu[]              @relation("MenuTree")
  roleMenus          RoleMenu[]
  pluginMenuBindings PluginMenuBinding[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([type])
  @@index([permissionCode])
  @@index([isExternal])
  @@index([keepAlive])
  @@index([affix])
  @@index([sortOrder])
  @@index([visible])
  @@index([enabled])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("menu")
}

model RoleMenu {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  menuId    String    @map("menu_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])
  menu      Menu      @relation(fields: [menuId], references: [id])

  @@unique([tenantId, roleId, menuId])
  @@index([tenantId])
  @@index([roleId])
  @@index([menuId])
  @@index([tenantId, roleId, menuId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("role_menu")
}

model RoleDataScope {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  resourceType String    @map("resource_type") @db.VarChar(80)
  scopeType    String    @map("scope_type") @db.VarChar(50)
  scopeValue   Json?     @map("scope_value")
  status       String    @default("ACTIVE") @db.VarChar(30)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  role         Role      @relation(fields: [roleId], references: [id])

  @@unique([tenantId, roleId, resourceType])
  @@index([tenantId])
  @@index([roleId])
  @@index([resourceType])
  @@index([scopeType])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("role_data_scope")
}

model ResourceAcl {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  resourceType   String    @map("resource_type") @db.VarChar(80)
  resourceId     String    @map("resource_id") @db.Uuid
  subjectType    String    @map("subject_type") @db.VarChar(50)
  subjectId      String    @map("subject_id") @db.Uuid
  permissionCode String    @map("permission_code") @db.VarChar(120)
  effect         String    @default("ALLOW") @db.VarChar(20)
  conditions     Json?
  status         String    @default("ACTIVE") @db.VarChar(30)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, resourceType, resourceId, subjectType, subjectId, permissionCode])
  @@index([tenantId])
  @@index([resourceType])
  @@index([resourceId])
  @@index([subjectType])
  @@index([subjectId])
  @@index([permissionCode])
  @@index([effect])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("resource_acl")
}

model ApiKey {
  id                     String            @id @default(uuid()) @db.Uuid
  tenantId               String            @map("tenant_id") @db.Uuid
  name                   String            @db.VarChar(160)
  keyPrefix              String            @map("key_prefix") @db.VarChar(30)
  keyHash                String            @map("key_hash") @db.VarChar(255)
  status                 String            @default("ACTIVE") @db.VarChar(30)
  scopes                 Json?
  allowedAgentIds        Json?             @map("allowed_agent_ids")
  ipAllowlist            Json?             @map("ip_allowlist")
  rateLimitPerMinute     Int               @default(60) @map("rate_limit_per_minute")
  dailyQuota             Int?              @map("daily_quota")
  usedCountToday         Int               @default(0) @map("used_count_today")
  quotaResetDate         DateTime?         @map("quota_reset_date") @db.Date
  allowStream            Boolean           @default(true) @map("allow_stream")
  webhookEnabled         Boolean           @default(false) @map("webhook_enabled")
  webhookUrl             String?           @map("webhook_url") @db.VarChar(1000)
  webhookEvents          Json?             @map("webhook_events")
  webhookSecretEncrypted String?           @map("webhook_secret_encrypted") @db.Text
  webhookLastStatus      String?           @map("webhook_last_status") @db.VarChar(30)
  webhookLastError       String?           @map("webhook_last_error") @db.Text
  webhookLastSentAt      DateTime?         @map("webhook_last_sent_at")
  expiresAt              DateTime?         @map("expires_at")
  lastUsedAt             DateTime?         @map("last_used_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  deletedAt              DateTime?         @map("deleted_at")
  createdBy              String?           @map("created_by") @db.Uuid
  updatedBy              String?           @map("updated_by") @db.Uuid
  tenant                 Tenant            @relation(fields: [tenantId], references: [id])
  webhookDeliveries      WebhookDelivery[]

  @@index([tenantId])
  @@index([status])
  @@index([rateLimitPerMinute])
  @@index([quotaResetDate])
  @@index([webhookEnabled])
  @@index([webhookLastSentAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("api_key")
}

model WebhookDelivery {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  apiKeyId         String            @map("api_key_id") @db.Uuid
  event            String            @db.VarChar(80)
  deliveryId       String            @unique @map("delivery_id") @db.VarChar(120)
  parentDeliveryId String?           @map("parent_delivery_id") @db.Uuid
  targetUrl        String            @map("target_url") @db.VarChar(1000)
  payload          Json
  requestHeaders   Json?             @map("request_headers")
  responseStatus   Int?              @map("response_status")
  responseBody     String?           @map("response_body") @db.Text
  latencyMs        Int?              @map("latency_ms")
  status           String            @db.VarChar(30)
  errorMessage     String?           @map("error_message") @db.Text
  retryCount       Int               @default(0) @map("retry_count")
  deliveredAt      DateTime?         @map("delivered_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  apiKey           ApiKey            @relation(fields: [apiKeyId], references: [id])
  parentDelivery   WebhookDelivery?  @relation("WebhookDeliveryRetryChain", fields: [parentDeliveryId], references: [id])
  retries          WebhookDelivery[] @relation("WebhookDeliveryRetryChain")

  @@index([tenantId])
  @@index([apiKeyId])
  @@index([event])
  @@index([deliveryId])
  @@index([parentDeliveryId])
  @@index([status])
  @@index([responseStatus])
  @@index([createdAt])
  @@index([deliveredAt])
  @@map("webhook_delivery")
}

model SystemSetting {
  id           String                  @id @default(uuid()) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  category     String                  @db.VarChar(80)
  key          String                  @db.VarChar(120)
  name         String                  @db.VarChar(160)
  description  String?                 @db.Text
  value        Json                    @default("{}")
  defaultValue Json                    @default("{}") @map("default_value")
  valueType    String                  @map("value_type") @db.VarChar(40)
  options      Json?
  isSecret     Boolean                 @default(false) @map("is_secret")
  isSystem     Boolean                 @default(true) @map("is_system")
  status       String                  @default("ACTIVE") @db.VarChar(30)
  sortOrder    Int                     @default(0) @map("sort_order")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  deletedAt    DateTime?               @map("deleted_at")
  createdBy    String?                 @map("created_by") @db.Uuid
  updatedBy    String?                 @map("updated_by") @db.Uuid
  tenant       Tenant                  @relation(fields: [tenantId], references: [id])
  updater      User?                   @relation("SystemSettingUpdater", fields: [updatedBy], references: [id])
  snapshots    SystemSettingSnapshot[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([category])
  @@index([key])
  @@index([valueType])
  @@index([isSecret])
  @@index([isSystem])
  @@index([status])
  @@index([sortOrder])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("system_setting")
}

model SystemSettingSnapshot {
  id                     String        @id @default(uuid()) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  settingId              String        @map("setting_id") @db.Uuid
  settingKey             String        @map("setting_key") @db.VarChar(120)
  settingName            String        @map("setting_name") @db.VarChar(160)
  version                Int
  action                 String        @db.VarChar(40)
  previousValue          Json          @default("{}") @map("previous_value")
  nextValue              Json          @default("{}") @map("next_value")
  previousStatus         String        @map("previous_status") @db.VarChar(30)
  nextStatus             String        @map("next_status") @db.VarChar(30)
  approvalStatus         String        @default("NOT_REQUIRED") @map("approval_status") @db.VarChar(40)
  approvalRequestId      String?       @map("approval_request_id") @db.VarChar(120)
  rollbackFromSnapshotId String?       @map("rollback_from_snapshot_id") @db.Uuid
  rollbackCount          Int           @default(0) @map("rollback_count")
  impactLevel            String?       @map("impact_level") @db.VarChar(30)
