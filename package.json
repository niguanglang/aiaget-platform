{
  "name": "aiaget",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:control-api": "set -a && . ./.env && set +a && pnpm --filter @aiaget/control-api dev",
    "dev:web": "set -a && . ./.env && set +a && pnpm --filter @aiaget/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.17",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1"
  }
}
