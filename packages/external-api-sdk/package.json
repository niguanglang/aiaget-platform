{
  "name": "@aiaget/external-api-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AIAGET Enterprise Agent Platform external APIs.",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/index.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "prepack": "pnpm build",
    "pack:check": "pnpm test && pnpm typecheck && pnpm typecheck:examples && pnpm build && npm pack --dry-run"
  }
}
